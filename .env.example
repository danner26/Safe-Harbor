# Flask
FLASK_APP=safeharbor.wsgi:app
FLASK_CONFIG=development
SECRET_KEY=change-me-in-prod

# Database
DATABASE_URL=postgresql+psycopg://safeharbor:safeharbor@postgres:5432/safeharbor

# Redis
REDIS_URL=redis://redis:6379/0

# Email (optional; BYO SMTP)
# SMTP is optional in production. Without SMTP_HOST, password-reset emails are
# not sent; admins can run `flask safeharbor reset-password <email>` to prompt
# for a new password and update the user directly.
# Setting SMTP_HOST enables the email pathway when actual SMTP-send code lands
# in a future release. SMTP_PORT/SMTP_USER/SMTP_PASS/SMTP_FROM only apply when
# SMTP_HOST is set.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=safeharbor@localhost

# Storage
STORAGE_DIR=/data/uploads

# Tank timezone fallback (optional)
# DEFAULT_TZ=America/New_York

# Logging
LOG_LEVEL=INFO

# Set to 1 if this app sits behind a trusted reverse proxy (Cloudflare Tunnel,
# nginx, traefik, Caddy, or any proxy that injects X-Forwarded-* headers).
# Default 0 is safe for direct-expose deployments where no proxy is in front.
TRUST_PROXY_HEADERS=0
# UPLOAD_DIR writability check (default 1 = required). The default backup
# sidecar mounts uploads read-write so it can write restored files. Set to 0
# only if you mount the uploads volume read-only in a custom deployment and
# want the app to skip the writability assertion at startup.
UPLOAD_DIR_REQUIRE_WRITABLE=1
# Gunicorn forwarded-IP allowlist (default '*' = trust all; tighten to known proxy IPs/CIDRs if static)
FORWARDED_ALLOW_IPS=*

# Application image version
# Default: latest (auto-upgrades on every `compose pull`).
# Pin to a specific tag (e.g., 1.0.0) for production stability.
# Tags published at https://github.com/danner26/Safe-Harbor/pkgs/container/safeharbor
SAFEHARBOR_VERSION=

# Public hostname (no scheme; e.g., safeharbor.example.com).
# Required if the app sends emails (password reset) so async URL generation
# produces correct links. Leave blank to derive from request Host header.
SERVER_NAME=
PREFERRED_URL_SCHEME=https

# Sentry (optional)
SENTRY_DSN=
# Sentry transactions sample rate; 0.0 = errors only
SENTRY_TRACES_SAMPLE_RATE=0.0

# Cloudflare Tunnel (optional)
# Cloudflare Tunnel token; required when using the `tunnel` compose profile
TUNNEL_TOKEN=

# Backups (optional, for the backup compose profile)
# Enable scheduled backups by adding 'backup' to COMPOSE_PROFILES (e.g., COMPOSE_PROFILES=tunnel,backup)
# ofelia 6-field cron expression; default = daily at 03:00 UTC
BACKUP_SCHEDULE=0 0 3 * * *
# keep this many recent tarballs regardless of weekday
BACKUP_RETENTION_DAILY=7
# additionally keep one tarball per ISO week up to this many weeks
BACKUP_RETENTION_WEEKLY=4

# Test DB (used by pytest fixtures in TestConfig; defaults to safeharbor_test on local Postgres)
TEST_DATABASE_URL=postgresql+psycopg://safeharbor:safeharbor@postgres:5432/safeharbor_test

# RQ workers (queues this worker process listens on, comma-separated)
RQ_QUEUES=default
