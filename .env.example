# Flask
FLASK_APP=safeharbor.wsgi:app
FLASK_CONFIG=development
SECRET_KEY=change-me-in-prod

# Database
DATABASE_URL=postgresql+psycopg://safeharbor:safeharbor@postgres:5432/safeharbor

# Redis
REDIS_URL=redis://redis:6379/0

# Email (BYO SMTP — Mailhog in dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=safeharbor@localhost

# Storage
STORAGE_DIR=/data/uploads

# Tank timezone fallback (optional)
# DEFAULT_TZ=America/New_York

# Logging
LOG_LEVEL=INFO

# Reverse-proxy trust (set to 0 if running without a trusted proxy/tunnel)
TRUST_PROXY_HEADERS=1
# Gunicorn forwarded-IP allowlist (default '*' = trust all; tighten to known proxy IPs/CIDRs if static)
FORWARDED_ALLOW_IPS=*

# Sentry (optional)
SENTRY_DSN=
# Sentry transactions sample rate; 0.0 = errors only
SENTRY_TRACES_SAMPLE_RATE=0.0

# Cloudflare Tunnel (optional)
# Cloudflare Tunnel token; required when using the `tunnel` compose profile
TUNNEL_TOKEN=

# Test DB (used by pytest fixtures in TestConfig; defaults to safeharbor_test on local Postgres)
TEST_DATABASE_URL=postgresql+psycopg://safeharbor:safeharbor@postgres:5432/safeharbor_test

# RQ workers (queues this worker process listens on, comma-separated)
RQ_QUEUES=default
